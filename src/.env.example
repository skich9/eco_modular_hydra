# SGA Electronica (PostgreSQL)
SGA_ELEC_DB_HOST=host.docker.internal
SGA_ELEC_DB_PORT=5432
SGA_ELEC_DB_DATABASE=
SGA_ELEC_DB_USERNAME=postgres
SGA_ELEC_DB_PASSWORD=admin
SGA_ELEC_DB_SCHEMA=public
SGA_ELEC_DB_SSLMODE=prefer

# SGA Mecánica (PostgreSQL)
SGA_MEC_DB_HOST=host.docker.internal
SGA_MEC_DB_PORT=5432
SGA_MEC_DB_DATABASE=
SGA_MEC_DB_USERNAME=postgres
SGA_MEC_DB_PASSWORD=admin
SGA_MEC_DB_SCHEMA=public
SGA_MEC_DB_SSLMODE=prefer

HYDRA_ASSIGN_SYNC=true
HYDRA_QUEUE_INSCRIPCIONES=default
QUEUE_CONNECTION=database
REDIS_CLIENT=phpredis
SESSION_DRIVER=file
CACHE_DRIVER=file
HYDRA_DEFAULT_USER_ID=1
SGA_WEBHOOK_TOKEN=
SGA_BASE_URL=http://localhost/sga4
SGA_USE_AUTORIZACIONES=false
# Si vas a probar autorizaciones con sesión SGA real (requiere login en SGA y copiar cookie de sesión):
# SGA_SESSION_COOKIE=ci_session=<valor>; otra_cookie=x

CORS_ALLOW_ALL=true
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://192.168.0.74:4200
CORS_SUPPORTS_CREDENTIALS=true
CORS_SUPPORTS_CREDENTIALS=false

HYDRA_INSCR_TIPO_COSTO_NORMAL="costo_mensual,costo_semestral"
HYDRA_INSCR_TIPO_COSTO_ARRASTRE="materia"

HYDRA_INSCR_TURNO_M="MANANA,MAÑANA,M"
HYDRA_INSCR_TURNO_T="TARDE,T"
HYDRA_INSCR_TURNO_N="NOCHE,N"

# Activa fallback pero, si es NORMAL, evita 'materia'
HYDRA_ASSIGN_FALLBACK_ANY_TIPO=true
HYDRA_FORBIDDEN_TIPO_COSTO_NORMAL="materia"

# SGA URLs por carrera
